# --- AWS Credentials ---
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_DEFAULT_REGION=us-east-1
AWS_REGIONS=us-east-1,us-east-2,us-west-1,us-west-2

# --- Budget Alert Settings ---
BUDGET_THRESHOLD=10

# --- Email Notification Settings ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
ALERT_FROM=your_email@gmail.com
ALERT_TO=your_email@gmail.com

# --- App Settings ---
SNAPSHOT_AGE_DAYS=30
EC2_CPU_THRESHOLD=5.0
DB_PATH=db/optimizer.db

# --- Optimizer Settings ---
OPTIMIZER_LOOKBACK_DAYS=7
OPTIMIZER_METRIC_PERIOD=3600
OPTIMIZER_FORECAST_HORIZON_HOURS=24
OPTIMIZER_MAX_RESOURCES=200
OPTIMIZER_CPU_LOW_PCT=15.0
OPTIMIZER_CPU_HIGH_PCT=80.0
OPTIMIZER_ALLOW_EC2_STOP=false
OPTIMIZER_ALLOW_EC2_RESIZE=true
OPTIMIZER_ALLOW_RDS_STOP=false
OPTIMIZER_MIN_CONFIDENCE=0.6
OPTIMIZER_MAX_EXPLANATIONS=10
AUTO_APPLY_OPTIMIZATIONS=false
FORECAST_MODEL_MIN_POINTS=21
LSTM_EPOCHS=120
LSTM_HIDDEN_SIZE=12
LSTM_LEARNING_RATE=0.01
LSTM_SEQUENCE_LENGTH=6
RL_QTABLE_PATH=rl_models/q_table.npy
RL_ALPHA=0.1
RL_GAMMA=0.9
RL_EPSILON=0.1
SLO_MAX_CPU=85
SLO_MAX_MEMORY=90
SLO_MAX_REQUESTS=2.0
SLO_MIN_REPLICAS=1
SLO_MAX_REPLICAS=8
SLO_MAX_SCALE_STEP=2
SLO_COOLDOWN_SECONDS=180

# --- Cloud AI ---
# GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here
